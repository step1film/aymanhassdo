# =====================================================
# STEP1FILM Store — hemliga nycklar (MALL)
# =====================================================
# Kopiera INTE in riktiga värden i git. Denna fil är bara
# en mall. De riktiga värdena läggs som miljövariabler hos
# din hosting (Netlify: Site settings → Environment variables).
#
# För lokal test kan du kopiera denna fil till ".env" och köra
# `netlify dev`. Filen ".env" är git-ignorerad.
# =====================================================

# --- Printful (tryck + leverans) ---
# Skapa i Printful: Settings → Developers → API access tokens
PRINTFUL_API_TOKEN=

# Valfritt. Behövs bara om ditt konto har flera stores.
PRINTFUL_STORE_ID=

# 'true' = lägg skarpa (debiterade) ordrar automatiskt.
# Lämna tomt/false medan du testar → ordrar skapas som utkast.
PRINTFUL_CONFIRM_ORDERS=

# --- Stripe (betalning) — läggs till i Steg 4c ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
